<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VR Trail Explorer</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">
    <h1 class="text-center">VR Trail Explorer</h1>
    <p class="text-center">Click a location to explore in 360°</p>

    <div class="row mt-4">

        <!-- Arkansas -->
        <div class="col-md-4">
            <h4>Arkansas</h4>

            <p>
                <a href="#" class="trail-link"
                   data-trail="Beaver Lake"
                   data-state="Arkansas"
                   data-location="Rogers, AR"
                   data-video="https://www.youtube.com/embed/g8gGlYtr96I">
                   Beaver Lake
                </a>
            </p>

            <p>
                <a href="#" class="trail-link"
                   data-trail="Lake Ouachita"
                   data-state="Arkansas"
                   data-location="Mountain Pine, AR"
                   data-video="https://www.youtube.com/embed/2QRuW4S0KvY">
                   Lake Ouachita
                </a>
            </p>
        </div>

        <!-- Georgia -->
        <div class="col-md-4">
            <h4>Georgia</h4>

            <p>
                <a href="#" class="trail-link"
                   data-trail="Allatoona Lake"
                   data-state="Georgia"
                   data-location="Cartersville, GA"
                   data-video="https://www.youtube.com/embed/gFT9-pzm2ws">
                   Allatoona Lake
                </a>
            </p>

            <p>
                <a href="#" class="trail-link"
                   data-trail="Carters Lake"
                   data-state="Georgia"
                   data-location="Ellijay, GA"
                   data-video="https://www.youtube.com/embed/lWsreyu6OWI">
                   Carters Lake
                </a>
            </p>
        </div>

        <!-- Missouri -->
        <div class="col-md-4">
            <h4>Missouri</h4>

            <p>
                <a href="#" class="trail-link"
                   data-trail="Table Rock Lake"
                   data-state="Missouri"
                   data-location="Branson, MO"
                   data-video="https://www.youtube.com/embed/2S0P9jVswps">
                   Table Rock Lake
                </a>
            </p>
        </div>

        <!-- Ohio -->
        <div class="col-md-4 mt-4">
            <h4>Ohio</h4>

            <p>
                <a href="#" class="trail-link"
                   data-trail="Beech Fork Lake"
                   data-state="Ohio"
                   data-location="Barboursville, WV"
                   data-video="https://www.youtube.com/embed/Dv0tVwF5Nbo">
                   Beech Fork Lake
                </a>
            </p>
        </div>

        <!-- West Virginia -->
        <div class="col-md-4 mt-4">
            <h4>West Virginia</h4>

            <p>
                <a href="#" class="trail-link"
                   data-trail="Alum Creek"
                   data-state="West Virginia"
                   data-location="South Charleston, WV"
                   data-video="https://www.youtube.com/embed/hBP_BNHXUy0">
                   Alum Creek
                </a>
            </p>
        </div>

    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="trailModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 id="modalTitle"></h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <p><strong>State:</strong> <span id="modalState"></span></p>
                <p><strong>Location:</strong> <span id="modalLocation"></span></p>

                <div class="ratio ratio-16x9">
                    <iframe id="modalVideo" src="" allowfullscreen></iframe>
                </div>

            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
document.querySelectorAll('.trail-link').forEach(link => {
    link.addEventListener('click', function(e) {
        e.preventDefault();

        const trail = this.dataset.trail;
        const state = this.dataset.state;
        const location = this.dataset.location;
        const video = this.dataset.video;

        document.getElementById('modalTitle').innerText = trail;
        document.getElementById('modalState').innerText = state;
        document.getElementById('modalLocation').innerText = location;
        document.getElementById('modalVideo').src = video;

        const modal = new bootstrap.Modal(document.getElementById('trailModal'));
        modal.show();
    });
});
</script>

</body>
</html>
